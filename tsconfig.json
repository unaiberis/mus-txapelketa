{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["svelte", "vite/client"],
    "jsx": "react-jsx",
    "allowJs": true
  },
  "include": ["src", "types"],
  "exclude": ["node_modules", "dist"]
}
