---
import Header from '../components/Header.astro';
import "../styles/global.css";
---

<html lang="eu">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Koadroa - Mus Txapelketa</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <div class="container--center">
      <Header showBack={true} />

      <main class="pt-14 w-full max-w-full p-0 h-screen m-0">
        <section id="koadroa-island" class="p-0 m-0 h-full flex items-center justify-center">
          <div class="p-8 text-center text-slate-600">El visor del cuadro ha sido eliminado en esta versión.</div>
        </section>
      </main>
    </div>
  </body>
</html>
