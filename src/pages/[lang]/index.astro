---
import '../../styles/global.css';
import TournamentApp from '../../components/TournamentApp';
import { DEFAULT_LANG, t } from '../../lib/i18n';

export async function getStaticPaths() {
  return ['es', 'en', 'fr', 'eu'].map((code) => ({ params: { lang: code } }));
}

const supported = ['es', 'en', 'fr', 'eu'];
const langParam = Astro.params.lang;
const lang = supported.includes(langParam) ? langParam : DEFAULT_LANG;

// For static sites we cannot read request cookies at build time. Inject an
// early inline script to apply theme from cookie or prefers-color-scheme.
const inlineThemeScript = `(function(){try{const m=document.cookie.match(/(?:^|; )theme=([^;]+)/); if(m&&m[1]==='dark'){document.documentElement.classList.add('dark');} else if(!m){ if(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches){document.documentElement.classList.add('dark');}}}catch(e){} })();`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t(lang, 'header.title')}</title>
  <script dangerouslySetInnerHTML={{ __html: inlineThemeScript }} />
  <!-- Preload self-hosted fonts (place files in public/fonts/) -->
  <link rel="preload" href="/fonts/BebasNeue-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/Inter-Medium.woff2" as="font" type="font/woff2" crossorigin />
  <!-- Fallback to Google Fonts if local files are not present -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <TournamentApp client:load initialLang={lang} />
</body>
</html>
