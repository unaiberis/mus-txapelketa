---
interface Props {
  showBack?: boolean;
}
const { showBack = false } = Astro.props as Props;
const BASE = import.meta.env.BASE_URL || "/";
---

<a href="#main" class="skip-link sr-only focus:not-sr-only" aria-label="Skip to main content">Skip to content</a>
<header class="py-3 container--center" role="banner">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      {showBack ? <a href={BASE} class="text-sm">← Volver</a> : null}
      <a href={BASE} class="flex items-center gap-3 no-underline">
        <div class="w-10 h-10 rounded-md bg-accent-400 flex items-center justify-center">M</div>
        <div>
          <div class="text-2xl font-bold">MUSeko</div>
          <div class="text-sm opacity-80">Generador de parejas y cuadro</div>
        </div>
      </a>
    </div>

    <div class="flex items-center gap-3">
      <nav class="hidden lg:flex items-center gap-3" aria-label="Main navigation">
        <a href={BASE}>Home</a>
        <a href="/koadroa/" class="px-3 py-1 rounded-pill bg-accent-400">Koadroa</a>
      </nav>

      <button id="theme-toggle" aria-pressed="false" aria-label="Toggle dark theme">Theme</button>
      <button id="mobile-menu-toggle" aria-expanded="false" aria-controls="mobile-links" aria-label="Open menu">Menu</button>
    </div>
  </div>

  <div id="mobile-links" class="hidden">
    <a href={BASE}>Home</a>
    <a href="/koadroa/">Koadroa</a>
  </div>
</header>

<script>
  const THEME_KEY = 'mus:theme';
  const darkClass = 'theme-dark';
  function isDarkStored(): boolean { try { return localStorage.getItem(THEME_KEY) === 'dark'; } catch(e){ return false; } }
  function persistDark(isDark: boolean){ try { localStorage.setItem(THEME_KEY, isDark ? 'dark' : 'light'); } catch(e){} }
  function apply(document: Document, isDark: boolean){ if(isDark) document.documentElement.classList.add(darkClass); else document.documentElement.classList.remove(darkClass); }
  const initialDark = isDarkStored() || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
  apply(document, initialDark);
  const btn = document.getElementById('theme-toggle'); if(btn) btn.addEventListener('click', function(){ const isDark = document.documentElement.classList.toggle(darkClass); persistDark(isDark); btn.setAttribute('aria-pressed', String(isDark)); });
  const mobileBtn = document.getElementById('mobile-menu-toggle'); const mobileLinks = document.getElementById('mobile-links'); if(mobileBtn && mobileLinks){ mobileBtn.addEventListener('click', function(){ mobileLinks.classList.toggle('hidden'); mobileBtn.setAttribute('aria-expanded', String(!mobileLinks.classList.contains('hidden'))); }); }
</script>

<style>
  .skip-link.sr-only { position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden; }
  .skip-link:focus { left: 0; top: 0; width: auto; height: auto; }
</style>

